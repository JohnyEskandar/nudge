# Copy to .env and fill in. All VITE_* vars are baked into the client bundle at
# build time, so only ever put public values here — never the service_role key.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# The VAPID public key, base64url. Must be the public half of the VAPID_KEYS pair
# set as a secret on the edge function. Generate both with:
#   node scripts/generate-vapid-keys.mjs
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
